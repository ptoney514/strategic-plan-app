# =============================================================================
# Strategic Plan Builder - Local Development Environment
# =============================================================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# =============================================================================

# DATABASE_URL — Neon branch to use for local development
# ⚠️  NEVER use the production connection string here.
# Three-tier DB setup: production (main branch) → preview (PR branch, auto-managed) → local dev (dev branch)
# Run `npm run db:dev:setup` to create/get the dev branch connection string.
# Format: postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/strategic-plan-db?sslmode=require
DATABASE_URL=

# Better Auth (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=<run 'openssl rand -hex 32' to generate>
BETTER_AUTH_URL=http://localhost:5174
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:5174
NEXT_PUBLIC_APP_URL=http://localhost:5174
NEXT_PUBLIC_ENVIRONMENT=development

# Cross-subdomain cookies: ".stratadash.org" for prod, ".lvh.me" for local subdomain testing
BETTER_AUTH_COOKIE_DOMAIN=

# E2E Testing
PLAYWRIGHT_BASE_URL=http://localhost:5174

# R2 Upload Worker (for logo uploads)
# Deploy the worker from cloudflare-workers/r2-upload-worker/
NEXT_PUBLIC_R2_UPLOAD_WORKER_URL=https://r2-upload-worker.pernell.workers.dev

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Production database guard — set to your Neon production endpoint hostname
# (e.g., ep-cool-darkness-123456). The seed script will refuse to run if
# DATABASE_URL contains this value.
NEON_PRODUCTION_ENDPOINT=

# Production database URL — used by backup script (npm run db:backup)
# Get from Neon Console → main branch → Connection Details
DATABASE_URL_PROD=

# Optional: Enable debug logging
# DEBUG=true

# Userjot Feedback Widget (disabled by default for local dev)
# Uncomment to test locally - feedback will go to your Userjot project
# NEXT_PUBLIC_USERJOT_PROJECT_ID=cmkibn7as04nk14q5ogovt4wy

# Sentry error monitoring (Phase 4 — requires sentry.io account)
# Create a project at https://sentry.io, copy the DSN here
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Upstash rate limiting (Phase 5 — requires upstash.com account)
# Create a Redis database at https://upstash.com, copy the REST URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
