# =============================================================================
# Strategic Plan Builder - Local Development Environment
# =============================================================================
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# =============================================================================

# Neon PostgreSQL (pooled connection string)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/strategic-plan-db?sslmode=require

# Better Auth (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=<run 'openssl rand -hex 32' to generate>
BETTER_AUTH_URL=http://localhost:5174
VITE_BETTER_AUTH_URL=http://localhost:5174
VITE_APP_URL=http://localhost:5174

# Cross-subdomain cookies: ".stratadash.org" for prod, ".lvh.me" for local subdomain testing
BETTER_AUTH_COOKIE_DOMAIN=

# E2E Testing
PLAYWRIGHT_BASE_URL=http://localhost:5174

# R2 Upload Worker (for logo uploads)
# Deploy the worker from cloudflare-workers/r2-upload-worker/
VITE_R2_UPLOAD_WORKER_URL=https://r2-upload-worker.pernell.workers.dev

# Optional: Enable debug logging
# DEBUG=true

# Userjot Feedback Widget (disabled by default for local dev)
# Uncomment to test locally - feedback will go to your Userjot project
# VITE_USERJOT_PROJECT_ID=cmkibn7as04nk14q5ogovt4wy
