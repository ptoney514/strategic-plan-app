# Staging Environment Variables
# Copy to .env.staging and fill in values from Supabase Dashboard

# Supabase Staging Project
# Get these from: supabase.com/dashboard/project/<ref>/settings/api
VITE_SUPABASE_URL=https://<your-staging-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-staging-anon-key>

# Optional: Userjot Feedback Widget (can use same as prod or disable)
# VITE_USERJOT_PROJECT_ID=your_userjot_project_id
