# Staging Environment Variables
# Copy to .env.staging and fill in values

# Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/strategic-plan-db?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=<run 'openssl rand -hex 32' to generate>
BETTER_AUTH_URL=https://staging.stratadash.org

# Frontend
VITE_API_BASE_URL=https://staging.stratadash.org

# Optional: Userjot Feedback Widget
# VITE_USERJOT_PROJECT_ID=your_userjot_project_id
