# =============================================================================
# Local Docker PostgreSQL - Development Environment
# =============================================================================
# Copy this file to .env.local to use the local Docker database.
# Replaces the Neon DATABASE_URL with a local connection.
#
# Quick start:
#   cp docker.env.example .env.local
#   npm run db:local:setup      # starts Docker, migrates, seeds
#   npm run dev:api              # full-stack dev server
# =============================================================================

# Local PostgreSQL (Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/strategic-plan-db

# Better Auth
BETTER_AUTH_SECRET=local-dev-secret-change-me-in-production
BETTER_AUTH_URL=http://localhost:5174
VITE_BETTER_AUTH_URL=http://localhost:5174
VITE_APP_URL=http://localhost:5174
