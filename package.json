{
  "name": "strategic-plan-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "NODE_OPTIONS='--import tsx' vercel dev --listen 5174",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "build:check": "tsc -b && vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc -b --noEmit",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "db:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "db:seed:fresh": "node --env-file=.env.local ./node_modules/.bin/drizzle-kit migrate && tsx --env-file=.env.local scripts/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:drizzle-studio": "drizzle-kit studio",
    "db:local:up": "docker compose up -d && until docker compose exec postgres pg_isready -U postgres -d strategic-plan-db > /dev/null 2>&1; do sleep 1; done && echo 'PostgreSQL is ready'",
    "db:local:down": "docker compose down",
    "db:local:migrate": "node --env-file=.env.local ./node_modules/.bin/drizzle-kit migrate",
    "db:local:triggers": "docker compose exec -T postgres psql -U postgres -d strategic-plan-db < drizzle/custom/0001_updated_at_trigger.sql",
    "db:local:seed": "tsx --env-file=.env.local scripts/seed.ts",
    "db:local:setup": "npm run db:local:up && npm run db:local:migrate && npm run db:local:triggers && npm run db:local:seed",
    "db:local:reset": "docker compose down -v && npm run db:local:setup",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 100"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@iconify/react": "^6.0.2",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.89.0",
    "@tanstack/react-query-devtools": "^5.89.0",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.4.18",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.544.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.63.0",
    "react-router-dom": "^7.9.1",
    "recharts": "^3.2.1",
    "tailwind-merge": "^3.3.1",
    "xlsx": "^0.18.5",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/ui": "^3.0.5",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "pg": "^8.18.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.43.0",
    "vite": "^6.3.6",
    "vitest": "^3.0.5"
  }
}
